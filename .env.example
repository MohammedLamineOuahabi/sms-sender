PORT=3000

# SEND_MODE can be 'termux' or 'gateway'
SEND_MODE=termux

# If SEND_MODE is gateway, set the URL here
GATEWAY_URL=http://192.168.1.100:8080/v1/sms

# Anti-ban Delays (in milliseconds)
# 5s to 15s is the "Extreme Safe" minimum for personal SIMs
DELAY_MIN=5000
DELAY_MAX=15000

# Batching Config
# Sending 20 messages then pausing for 2 minutes is safer for high-speed
BATCH_SIZE=20
BATCH_PAUSE=120000 
